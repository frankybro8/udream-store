# ═══════════════════════════════════════════════════
# Udream environment variables
# Copy this file to .env for local development.
# For Railway: set each variable in the Railway dashboard
# (Project → Variables) — DO NOT commit your real .env.
# ═══════════════════════════════════════════════════

# Gmail for newsletter / coupon emails
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_FROM_NAME=Udream

# Server port (Railway sets this automatically — leave empty there)
PORT=3001

# Where admin-*.json files are stored.
# Local dev: leave empty (defaults to project folder)
# Railway:   set to /data and mount a Railway Volume at /data
DATA_DIR=
